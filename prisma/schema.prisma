generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id         String   @id @default(cuid())
  title      String
  lyrics     String?
  artist     String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  image      String?
  slug       String    @unique
  youtubeUrl String?
  comments   Comment[]
}

model Admin {
  id       String @id @default(cuid())
  username String @unique
  password String
}

model Setting {
  key   String @id
  value String
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  author    String   @default("Anonymous")
  createdAt DateTime @default(now())
  songId    String
  song      Song     @relation(fields: [songId], references: [id], onDelete: Cascade)
}
